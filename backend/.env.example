# 백엔드 환경변수 예시 — 실제 값은 .env 에 작성 (gitignore 처리됨)
PORT=4000

# PostgreSQL 연결 문자열
# 로컬(docker-compose): postgres://scanner:scanner@localhost:5432/secret_scanner
# 컨테이너 내부:        postgres://scanner:scanner@db:5432/secret_scanner
DATABASE_URL=postgres://scanner:scanner@localhost:5432/secret_scanner

# Google Gemini API 키 (AI 보조 분석용) — https://aistudio.google.com 에서 발급
GOOGLE_GENERATIVE_AI_API_KEY=
# AI 모델 (선택, 기본 gemini-2.5-flash)
AI_MODEL=gemini-2.5-flash
